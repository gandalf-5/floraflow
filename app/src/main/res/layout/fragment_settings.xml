<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="100dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:fontFamily="@font/playfair_display_bold" />

        <!-- ══════════════════ PREMIUM CARD ══════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/premium_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Top row: branding + status badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌿 FloraFlow"
                            android:textColor="#AAFFDDAA"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_medium"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium"
                            android:textColor="#FFFFFFFF"
                            android:textSize="28sp"
                            android:fontFamily="@font/playfair_display_bold" />

                    </LinearLayout>

                    <!-- Badge: FREE PLAN or ACTIVE -->
                    <TextView
                        android:id="@+id/premium_status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_surface"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="@string/premium_badge_free"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_medium" />

                </LinearLayout>

                <!-- Feature list (free users only) -->
                <LinearLayout
                    android:id="@+id/premium_features_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_unlock_intro"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_medium"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_1"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_2"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_3"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_4"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_5"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_feature_6"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular" />

                </LinearLayout>

                <!-- Price note -->
                <TextView
                    android:id="@+id/premium_price_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/premium_price_note"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_regular"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <!-- Upgrade CTA button (free users) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/upgrade_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/premium_upgrade_cta"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"
                    app:backgroundTint="#FFFFFFFF"
                    app:cornerRadius="14dp"
                    app:rippleColor="@color/primary" />

                <!-- Premium active message (premium users) -->
                <LinearLayout
                    android:id="@+id/premium_active_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_active_thanks"
                        android:textColor="#EEFFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/premium_active_all_unlocked"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section: Wallpaper -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:text="@string/wallpaper"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <!-- Auto-Sync Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Auto-sync toggle row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_sync_wallpaper"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/auto_sync_description"
                            android:textColor="@color/text_tertiary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_regular"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/auto_sync_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color" />

                </LinearLayout>

                <!-- Wallpaper Time Row -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp" />

                <LinearLayout
                    android:id="@+id/wallpaper_time_row"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wallpaper_time"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular" />

                    <TextView
                        android:id="@+id/wallpaper_time_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary" />

                </LinearLayout>

                <!-- Wallpaper Target Row -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp" />

                <LinearLayout
                    android:id="@+id/wallpaper_target_row"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wallpaper_target"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular" />

                    <TextView
                        android:id="@+id/wallpaper_target_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary" />

                </LinearLayout>

                <!-- Auto-Refresh Interval Row (Premium) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp" />

                <LinearLayout
                    android:id="@+id/wallpaper_interval_row"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wallpaper_interval"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular" />

                    <TextView
                        android:id="@+id/wallpaper_interval_premium_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_surface"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="PREMIUM"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter_medium"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/wallpaper_interval_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:visibility="gone" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section: Discovery -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:text="@string/discovery"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Categories Row -->
                <LinearLayout
                    android:id="@+id/categories_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preferred_categories"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/categories_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_tertiary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_regular" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section: Notifications -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:text="@string/notifications"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/daily_notification"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/daily_notification_desc"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/notifications_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    app:thumbTint="@color/switch_thumb_color"
                    app:trackTint="@color/switch_track_color" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section: Appearance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:text="@string/appearance"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:id="@+id/dark_mode_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dark_mode"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular" />

                <TextView
                    android:id="@+id/dark_mode_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_tertiary" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section: About -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:text="@string/about"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/playfair_display_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/about_description"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"
                    android:lineSpacingMultiplier="1.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/powered_by_unsplash"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_regular" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="24dp">

    <!-- Season Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/season_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/season_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/season_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1B2E1F"
                    android:textSize="18sp"
                    android:fontFamily="@font/playfair_display_bold" />

                <TextView
                    android:id="@+id/plant_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#557A60"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Horizontal scroll of plant cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/plants_recycler"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false" />

</LinearLayout>

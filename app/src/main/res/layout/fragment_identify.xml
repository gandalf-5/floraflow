<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="100dp"
        android:paddingHorizontal="24dp">

        <!-- Header row: title + gallery shortcut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/identify"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:fontFamily="@font/playfair_display_bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/my_identifications_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/my_identifications"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                app:icon="@drawable/ic_history"
                app:iconTint="@color/primary"
                app:iconSize="16dp"
                app:iconPadding="4dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/identify_subtitle"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingMultiplier="1.5" />

        <!-- Daily counter chip (hidden for premium users) -->
        <TextView
            android:id="@+id/daily_counter_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_surface"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone" />

        <!-- Photo Picker Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/gallery_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/from_gallery"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                app:backgroundTint="@color/surface"
                app:cornerRadius="24dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/camera_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/take_photo"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                app:backgroundTint="@color/primary"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

        </LinearLayout>

        <!-- Placeholder -->
        <LinearLayout
            android:id="@+id/placeholder_group"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/rounded_surface"
            android:alpha="0.6">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/select_photo_hint"
                android:textColor="@color/text_tertiary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />

        </LinearLayout>

        <!-- Preview Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/preview_image"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FloraFlow.RoundedImage"
            app:strokeWidth="0dp"
            android:visibility="gone" />

        <!-- Identify Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/identify_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="@string/identify_button"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            android:visibility="gone" />

        <!-- Progress -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/identify_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:indeterminate="true"
            app:indicatorColor="@color/primary"
            android:visibility="gone" />

        <!-- Error -->
        <TextView
            android:id="@+id/error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#CC0000"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/result_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/identification_result"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_medium"
                    android:letterSpacing="0.15"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/result_common_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:fontFamily="@font/playfair_display_bold" />

                <TextView
                    android:id="@+id/result_scientific_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_tertiary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/result_family"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/result_confidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Care Tips Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/care_tips_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌿 Care Guide"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_medium"
                        android:letterSpacing="0.15"
                        android:textAllCaps="true" />

                    <ProgressBar
                        android:id="@+id/care_tips_progress"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- 💧 Watering -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="💧" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Watering" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_watering" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ☀️ Light -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="☀️" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Light" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_light" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🌱 Soil -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="🌱" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Soil" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_soil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🌡️ Temperature -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="🌡️" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temperature" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_temperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🐾 Toxicity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="🐾" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pet &amp; Human Safety" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_toxicity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🌿 Seasonal tip -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="top">
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="📅" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seasonal Tip" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/care_seasonal_tip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:fontFamily="@font/inter_regular" android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Share Discovery Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/share_result_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/share_discovery"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="@color/primary"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_share"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            android:visibility="gone" />

        <!-- Reset Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/reset_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/identify_another"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="@color/surface"
            app:cornerRadius="24dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            android:visibility="gone" />

        <!-- Read the Story button (shown after identification) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/story_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/read_the_story"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="@color/surface"
            app:cornerRadius="26dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            app:icon="@drawable/ic_notes"
            app:iconGravity="textStart"
            app:iconTint="@color/primary"
            app:iconPadding="8dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>

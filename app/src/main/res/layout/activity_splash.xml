<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_splash_leaf"
        app:tint="@color/splash_icon"
        app:layout_constraintBottom_toTopOf="@id/splash_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="FloraFlow"
        android:textColor="@color/splash_text"
        android:textSize="44sp"
        android:fontFamily="@font/playfair_display_bold"
        android:letterSpacing="0.01"
        app:layout_constraintBottom_toTopOf="@id/splash_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splash_logo" />

    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Botanical Discovery"
        android:textColor="@color/splash_subtitle"
        android:textSize="15sp"
        android:fontFamily="@font/inter_regular"
        android:letterSpacing="0.18"
        android:textAllCaps="true"
        app:layout_constraintBottom_toTopOf="@id/splash_tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splash_title" />

    <!-- Decorative divider line -->
    <View
        android:id="@+id/splash_divider"
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="#3374C69D"
        app:layout_constraintBottom_toTopOf="@id/splash_tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splash_subtitle" />

    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:layout_marginTop="12dp"
        android:text="@string/splash_tagline"
        android:textColor="@color/splash_hint"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splash_divider" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="#30000000"
        android:layout_marginBottom="4dp" />

    <!-- Header card — dark green -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B3A2A"
        android:paddingHorizontal="28dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿"
            android:textSize="36sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="FloraFlow"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="@font/playfair_display_bold"
            android:letterSpacing="0.02" />

        <!-- PREMIUM badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="PREMIUM"
            android:textColor="#A8D5A2"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.25"
            android:background="@drawable/badge_premium_outline"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/premium_price_header"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/playfair_display_bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/premium_price_note"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center" />

    </LinearLayout>

    <!-- Comparison table -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp">

        <!-- Table header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/table_feature"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:letterSpacing="0.12"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="@string/table_free"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:letterSpacing="0.12"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="@string/table_premium"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:letterSpacing="0.12"
                android:textAllCaps="true" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#12000000" />

        <!-- Row: Daily discovery -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_discovery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Identifications -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_identify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Botanical story (etymology) -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_story_basic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Full story (history, folklore, ecology) -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_story_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Auto wallpaper -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Identified plant as wallpaper -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_ident_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: Gallery -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_gallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Row: PDF export -->
        <include layout="@layout/item_premium_row"
            android:id="@+id/row_pdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- CTA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/premium_cta_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/premium_upgrade_cta"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="#1B3A2A"
            app:cornerRadius="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/premium_coming_soon_note"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
